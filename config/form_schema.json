{
  "title": "Phiếu thu thập thông tin BCHQS",
  "description": "Web app thu thập thông tin công dân phục vụ quản lý hồ sơ và cập nhật dữ liệu vào ứng dụng BCHQS.",
  "sections": [
    {
      "id": "personal_basic",
      "title": "Thông tin cá nhân",
      "description": "Các trường được tổng hợp từ biểu mẫu thông tin cơ bản của công dân.",
      "fields": [
        { "id": "full_name", "label": "Họ và tên công dân", "type": "text", "required": true },
        { "id": "date_of_birth", "label": "Ngày tháng năm sinh", "type": "date", "required": true },
        { "id": "gender", "label": "Giới tính", "type": "select", "required": true, "options": ["Nam", "Nữ"] },
        { "id": "citizen_id_number", "label": "Số căn cước công dân", "type": "text", "required": true },
        { "id": "phone", "label": "Số điện thoại cá nhân", "type": "tel", "required": true },
        { "id": "birth_registration_place", "label": "Nơi đăng ký khai sinh", "type": "text", "required": false },
        { "id": "street_address", "label": "Địa chỉ, số nhà", "type": "text", "required": true },
        {
          "id": "neighborhood",
          "label": "Khu phố",
          "type": "select",
          "required": true,
          "options": [
            "Hoa Lư",
            "Quanh Vinh",
            "Cây Chôm",
            "Bình Thiện",
            "Bửu Sơn",
            "Hòa Bình",
            "Xóm Vườn",
            "Thạnh Thới",
            "Tân Lân",
            "Sân Bay",
            "Thống Nhất",
            "Mương Sao",
            "Nhà Xanh",
            "Gò Me",
            "Bình Trước",
            "Đồi Phước",
            "Vĩnh Thành",
            "Nhất Hòa",
            "Nhị Hòa",
            "Tam Hòa",
            "Bình Đa",
            "Bàn Cờ",
            "Đồng Tâm",
            "Bình An",
            "An Bình",
            "Lam Sơn",
            "An Hảo",
            "Đoàn Kết",
            "Khu Công Nghiệp",
            "Tân Bình",
            "KP5 An Bình",
            "Vườn Mít",
            "Nam Hà",
            "Trung Dũng",
            "Biên Hùng",
            "Trung Kiên",
            "Phi Trường",
            "Ngã Ba Thành",
            "Thanh Bình",
            "Sông Phố",
            "Khánh Hưng",
            "Quyết Thắng",
            "Phước Lý",
            "Công Lý",
            "Bình Thành",
            "Tân Lại",
            "Tân Thành",
            "Tân Bửu",
            "Bửu Long"
          ]
        },
        { "id": "ward", "label": "Phường", "type": "text", "required": true, "default": "Trấn Biên" },
        { "id": "province", "label": "Tỉnh/Thành phố", "type": "text", "required": true, "default": "Đồng Nai" },
        { "id": "family_permanent_residence", "label": "Nơi thường trú của gia đình", "type": "text", "required": true },
        { "id": "current_residence", "label": "Nơi ở hiện tại", "type": "text", "required": true },
        { "id": "hometown", "label": "Quê quán", "type": "text", "required": true },
        { "id": "ethnicity", "label": "Dân tộc", "type": "text", "required": true },
        { "id": "religion", "label": "Tôn giáo", "type": "text", "required": true },
        { "id": "nationality", "label": "Quốc tịch", "type": "text", "required": true, "default": "Việt Nam" },
        { "id": "family_background", "label": "Thành phần gia đình", "type": "text", "required": true },
        { "id": "personal_background", "label": "Thành phần bản thân", "type": "text", "required": true },
        { "id": "education_level", "label": "Trình độ văn hóa", "type": "text", "required": true, "placeholder": "Ví dụ: 12/12" },
        {
          "id": "training_level",
          "label": "Trình độ đào tạo",
          "type": "select",
          "required": true,
          "options": ["Không", "Trung cấp", "Cao đẳng", "Đại học", "Sau đại học"]
        },
        { "id": "major", "label": "Chuyên ngành đào tạo", "type": "text", "required": false },
        { "id": "foreign_language", "label": "Trình độ ngoại ngữ", "type": "text", "required": false },
        { "id": "occupation", "label": "Nghề nghiệp hiện tại", "type": "text", "required": false },
        { "id": "salary_grade", "label": "Lương ngạch", "type": "text", "required": false },
        { "id": "salary_step", "label": "Bậc lương", "type": "text", "required": false },
        { "id": "workplace", "label": "Nơi làm việc", "type": "text", "required": false },
        { "id": "youth_union_join_date", "label": "Ngày vào Đoàn", "type": "date", "required": false },
        { "id": "party_join_date", "label": "Ngày vào Đảng", "type": "date", "required": false },
        { "id": "party_official_date", "label": "Ngày chính thức vào Đảng", "type": "date", "required": false },
        { "id": "reward_record", "label": "Khen thưởng", "type": "text", "required": false },
        { "id": "discipline_record", "label": "Kỷ luật", "type": "text", "required": false }
      ]
    },
    {
      "id": "personal_history",
      "title": "Lý lịch bản thân",
      "description": "Mỗi dòng mô tả giai đoạn học tập, làm việc hoặc cư trú của công dân.",
      "repeatable": true,
      "min_items": 1,
      "item_label": "Giai đoạn",
      "fields": [
        { "id": "stage_name", "label": "Tên giai đoạn", "type": "text", "required": true, "placeholder": "Ví dụ: Cấp 1, Cấp 2, Đại học" },
        { "id": "from_year", "label": "Từ năm", "type": "number", "required": true },
        { "id": "to_year", "label": "Đến năm", "type": "number", "required": true },
        { "id": "summary", "label": "Học gì hoặc làm gì, ở đâu", "type": "textarea", "required": true }
      ]
    },
    {
      "id": "family_basic",
      "title": "Thông tin gia đình",
      "description": "Thông tin cơ bản về cha mẹ và vị trí của công dân trong gia đình.",
      "fields": [
        { "id": "father_name", "label": "Họ và tên cha", "type": "text", "required": true },
        { "id": "father_date_of_birth", "label": "Ngày tháng năm sinh cha", "type": "date", "required": true },
        { "id": "father_phone", "label": "Số điện thoại cha", "type": "tel", "required": true },
        { "id": "father_current_residence", "label": "Nơi ở hiện tại của cha", "type": "textarea", "required": true },
        { "id": "father_occupation", "label": "Nghề nghiệp cha", "type": "text", "required": true },
        { "id": "father_status", "label": "Tình trạng cha", "type": "radio", "required": true, "options": ["Sống", "Chết"] },
        { "id": "mother_name", "label": "Họ và tên mẹ", "type": "text", "required": true },
        { "id": "mother_date_of_birth", "label": "Ngày tháng năm sinh mẹ", "type": "date", "required": true },
        { "id": "mother_phone", "label": "Số điện thoại mẹ", "type": "tel", "required": true },
        { "id": "mother_current_residence", "label": "Nơi ở hiện tại của mẹ", "type": "textarea", "required": true },
        { "id": "mother_occupation", "label": "Nghề nghiệp mẹ", "type": "text", "required": true },
        { "id": "mother_status", "label": "Tình trạng mẹ", "type": "radio", "required": true, "options": ["Sống", "Chết"] },
        { "id": "total_children", "label": "Cha mẹ có bao nhiêu người con", "type": "number", "required": true },
        { "id": "birth_order", "label": "Bản thân là con thứ mấy", "type": "number", "required": true },
        { "id": "daughters_count", "label": "Trong nhà có bao nhiêu con gái", "type": "number", "required": true },
        { "id": "sons_count", "label": "Trong nhà có bao nhiêu con trai", "type": "number", "required": true },
        { "id": "family_notes", "label": "Ghi chú thêm về tình hình kinh tế/chính trị gia đình", "type": "textarea", "required": false }
      ]
    },
    {
      "id": "marital_basic",
      "title": "Thông tin hôn nhân",
      "description": "Thông tin vợ/chồng và con cái để hoàn thiện hồ sơ lý lịch.",
      "fields": [
        { "id": "marital_status", "label": "Tình trạng hôn nhân", "type": "select", "required": false, "options": ["Chưa kết hôn", "Đã kết hôn"] },
        { "id": "spouse_name", "label": "Họ tên vợ/chồng", "type": "text", "required": false },
        { "id": "spouse_date_of_birth", "label": "Ngày tháng năm sinh vợ/chồng", "type": "date", "required": false },
        { "id": "spouse_occupation", "label": "Nghề nghiệp vợ/chồng", "type": "text", "required": false },
        { "id": "spouse_current_residence", "label": "Nơi ở hiện tại của vợ/chồng", "type": "textarea", "required": false },
        { "id": "children_count", "label": "Bản thân đã có bao nhiêu con", "type": "number", "required": false },
        { "id": "spouse_notes", "label": "Ghi chú thêm về vợ/chồng", "type": "textarea", "required": false }
      ]
    },
    {
      "id": "siblings",
      "title": "Thông tin anh chị em",
      "description": "Có thể thêm nhiều anh/chị/em trong gia đình.",
      "repeatable": true,
      "min_items": 0,
      "item_label": "Anh/chị/em",
      "fields": [
        { "id": "full_name", "label": "Họ và tên anh/chị/em", "type": "text", "required": true },
        { "id": "date_of_birth", "label": "Ngày tháng năm sinh", "type": "date", "required": true },
        { "id": "relation", "label": "Quan hệ với công dân", "type": "select", "required": true, "options": ["Anh trai", "Chị gái", "Em trai", "Em gái"] },
        { "id": "occupation", "label": "Nghề nghiệp", "type": "text", "required": true },
        { "id": "workplace", "label": "Nơi học tập/làm việc", "type": "text", "required": true },
        { "id": "current_residence", "label": "Nơi ở hiện tại", "type": "textarea", "required": false },
        { "id": "notes", "label": "Ghi chú thêm", "type": "textarea", "required": false }
      ]
    },
    {
      "id": "children",
      "title": "Thông tin con",
      "description": "Khai thêm thông tin con của công dân nếu đã có gia đình.",
      "repeatable": true,
      "min_items": 0,
      "item_label": "Con",
      "fields": [
        { "id": "full_name", "label": "Họ và tên con", "type": "text", "required": true },
        { "id": "date_of_birth", "label": "Ngày tháng năm sinh", "type": "date", "required": true },
        { "id": "occupation", "label": "Học tập/Nghề nghiệp", "type": "text", "required": false },
        { "id": "current_residence", "label": "Nơi ở hiện tại", "type": "textarea", "required": false },
        { "id": "notes", "label": "Ghi chú thêm", "type": "textarea", "required": false }
      ]
    },
    {
      "id": "father_history",
      "title": "Lý lịch cha",
      "description": "Từng giai đoạn từ nhỏ đến hiện tại của cha.",
      "repeatable": true,
      "min_items": 1,
      "item_label": "Giai đoạn của cha",
      "fields": [
        { "id": "from_year", "label": "Từ năm", "type": "number", "required": true },
        { "id": "to_year", "label": "Đến năm", "type": "number", "required": true },
        { "id": "summary", "label": "Ở đâu, làm gì", "type": "textarea", "required": true }
      ]
    },
    {
      "id": "mother_history",
      "title": "Lý lịch mẹ",
      "description": "Từng giai đoạn từ nhỏ đến hiện tại của mẹ.",
      "repeatable": true,
      "min_items": 1,
      "item_label": "Giai đoạn của mẹ",
      "fields": [
        { "id": "from_year", "label": "Từ năm", "type": "number", "required": true },
        { "id": "to_year", "label": "Đến năm", "type": "number", "required": true },
        { "id": "summary", "label": "Ở đâu, làm gì", "type": "textarea", "required": true }
      ]
    }
  ]
}
